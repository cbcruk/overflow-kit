{
  "name": "@overflow-kit/utils",
  "version": "0.1.0",
  "description": "Shared utilities for overflow-kit packages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "keywords": [
    "overflow",
    "utilities",
    "resize-observer"
  ],
  "author": "cbcruk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbcruk/overflow-kit.git",
    "directory": "packages/utils"
  },
  "homepage": "https://github.com/cbcruk/overflow-kit#readme",
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
