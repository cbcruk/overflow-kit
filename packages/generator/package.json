{
  "name": "@overflow-kit/generator",
  "version": "0.1.0",
  "description": "Generator-based DOM measurement for overflow detection",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "overflow",
    "generator",
    "dom-measurement",
    "truncation",
    "react"
  ],
  "author": "cbcruk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbcruk/overflow-kit.git",
    "directory": "packages/generator"
  },
  "homepage": "https://github.com/cbcruk/overflow-kit#readme",
  "dependencies": {
    "@overflow-kit/core": "workspace:*",
    "@overflow-kit/utils": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
