    "publish:packages": "pnpm -r publish --access public"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.11.0",
    "@vitest/browser-playwright": "^4.0.16",
    "eslint": "^9.17.0",
    "playwright": "^1.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.0.16"
  }
}
